<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.image-compressor</string>

    <key>ProgramArguments</key>
    <array>
      <string>node</string>
      <string>/path/to/app/index.js</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/image-compressor.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/image-compressor.log</string>
  </dict>
</plist>
